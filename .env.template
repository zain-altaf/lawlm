# Required: API key for fetching legal documents from CourtListener
# Get your API key from: https://www.courtlistener.com/api/
CASELAW_API_KEY=your_courtlistener_api_key_here

# Required: Qdrant URL for vector database
# For local Docker instance (default): http://localhost:6333
QDRANT_URL=http://localhost:6333

# Optional: OpenAI API key for RAG query summaries
# Only needed if you want AI-generated summaries via the chatbot interface
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here